# ─────────────────────────────────────────────────────────────────────────────
# NovaProspect — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values.
# .env is gitignored — never commit secrets.

# === LLM (xAI Grok via Responses API) ===
GROK_API_KEY=xai-uw4qHwOOIMkZI9ULx3KZnICZHw2qPqODoc8zVwxw9Lwk2Cu0HuC9VKIBJzYvwOe4P9FzyEFs8psOOo1L
GROK_MODEL=grok-4.20-reasoning
GROK_API_BASE=https://api.x.ai/v1
LLM_MAX_TOKENS=16000
LLM_TIMEOUT_S=600

# === Wasabi S3 (source of truth for ALL data) ===
WASABI_ACCESS_KEY=PASTE-YOUR-WASABI-ACCESS-KEY
WASABI_SECRET_KEY=PASTE-YOUR-WASABI-SECRET-KEY
WASABI_REGION=us-west-1
WASABI_BUCKET_RAW=sierra-geo-harvester
WASABI_BUCKET_DATA=sierra-cell-data
WASABI_BUCKET_LOGS=sierra-logs

# === EMIT mineral lookup (key inside WASABI_BUCKET_RAW) ===
EMIT_MINERAL_CSV_S3_KEY=reference/mineral_grouping_matrix_20230503.csv

# === Local cache (ephemeral — wiped anytime, rebuilt from Wasabi) ===
LOCAL_CACHE_DIR=/root/.sierra-cache
MAX_CACHE_GB=100

# === Tuning ===
MAX_WORKERS=4
MAX_API_CALLS_PER_RUN=200
AGENT_PHASE=testing

# === HDF5 (belt-and-suspenders — conda-forge HDF5 is thread-safe, but harmless) ===
HDF5_USE_FILE_LOCKING=FALSE
